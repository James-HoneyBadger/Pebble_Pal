{
  "name": "pebble-pal",
  "version": "1.0.0",
  "description": "A fun Pebble Pal virtual pet game",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "build:all": "electron-builder --win --mac --linux",
    "copy:web": "mkdir -p www && cp index.html style.css game.js www/",
    "ios:sync": "npm run copy:web && npx cap sync ios",
    "ios:open": "npx cap open ios",
    "ios:run": "npm run ios:sync && npx cap run ios",
    "android:sync": "npm run copy:web && npx cap sync android",
    "android:open": "npx cap open android",
    "android:run": "npm run android:sync && npx cap run android"
  },
  "author": "James",
  "license": "MIT",
  "devDependencies": {
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.pebblepal.app",
    "productName": "Pebble Pal",
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "style.css",
      "game.js",
      "icons/**"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "icons/icon.png"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "icons/icon.png",
      "category": "public.app-category.games"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "icons/icon.png",
      "category": "Game"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false
    }
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.2.0",
    "@capacitor/local-notifications": "^8.1.0"
  }
}
