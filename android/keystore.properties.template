# Copy this file to keystore.properties and fill in your values.
# NEVER commit keystore.properties to version control.
#
# Generate your keystore with:
#   keytool -genkey -v \
#     -keystore pebble-pal-release.jks \
#     -alias pebblepal \
#     -keyalg RSA -keysize 2048 \
#     -validity 10000 \
#     -dname "CN=Your Name, O=Pebble Pal, L=City, ST=State, C=US"

storeFile=../../pebble-pal-release.jks
storePassword=YOUR_STORE_PASSWORD
keyAlias=pebblepal
keyPassword=YOUR_KEY_PASSWORD
